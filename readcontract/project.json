{
  "name": "readcontract",
  "projectType": "capability",
  "projectRoot": "capabilities/kvstore",
  "implicitDependencies": ["types"],
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "golangci-lint run ."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go mod tidy"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go build -o ./../../bin/{projectName} ."
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "grep -rl \"^// Code generated by \"| xargs -r rm",
          "go generate -x ./..."
        ],
        "parallel": false
      }
    }
  }
}
