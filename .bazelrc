build --define gotags=purego
build --linkopt=-Wl,-no_warn_duplicate_libraries # Ignore duplicate libraries warning

# Default build platform is Macs
build --platforms=@rules_go//go/toolchain:darwin_arm64_cgo

# Builds for Linux
build:linux-amd64 --platforms=@rules_go//go/toolchain:linux_amd64_cgo
build:linux-arm64 --platforms=@rules_go//go/toolchain:linux_arm64_cgo

# Builds for Macs
build:darwin-amd64 --platforms=@rules_go//go/toolchain:darwin_amd64_cgo # Intel Macs
build:darwin-arm64 --platforms=@rules_go//go/toolchain:darwin_arm64_cgo # Apple Silicon Macs (M1/M2/M3)
