load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "server",
    srcs = ["server.go"],
    importpath = "github.com/smartcontractkit/capabilities/kvstore/server",
    visibility = ["//visibility:public"],
    deps = [
        "//kvstore/action",
        "//kvstore/kvrequests",
        "//kvstore/oracle",
        "//kvstore/target",
        "@com_github_smartcontractkit_chainlink_common//pkg/capabilities",
        "@com_github_smartcontractkit_chainlink_common//pkg/logger",
