go_test(
    name = "server_test",
    srcs = ["server_test.go"],
    deps = [
        ":server",
        "//libs/testutils",
        "@com_github_smartcontractkit_chainlink_common//pkg/services/servicetest",
        "@com_github_smartcontractkit_chainlink_common//pkg/types/core",
        "@com_github_stretchr_testify//require",
    ],
