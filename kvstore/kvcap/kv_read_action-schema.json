{
  "$id": "https://github.com/smartcontractkit/capabilities/kvstore/kvcap/kv-store-action@1.0.0",
  "$defs": {
    "ActionInputs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Input parameters for the Key-Value Store Action.",
      "properties": {
        "keys": {
          "type": "array",
          "description": "Keys to read from the Key-Value Store.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["keys"]
    },
    "ActionOutputs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Outputs of the Key-Value Store Action.",
      "properties": {
        "values": {
          "type": "array",
          "description": "Values read from the Key-Value Store.",
          "items": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255,
              "description": "Byte values"
            }
          }
        }
      },
      "required": ["values"]
    }
  },
  "description": "Key-Value Store Action",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "inputs": {
      "$ref": "#/$defs/ActionInputs"
    },
    "outputs": {
      "$ref": "#/$defs/ActionOutputs"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration for the Key-Value Store Action. No configuration options are available at this time.",
      "properties": {},
      "required": []
    }
  },
  "required": ["inputs"]
}
