load("@rules_go//go:def.bzl", "go_library")

# gazelle:exclude gen.go
# gazelle:exclude kvcaptest

filegroup(
    name = "schemas",
    srcs = [
        "kv_read_action-schema.json",
        "kv_write_target-schema.json",
    ],
    visibility = ["//visibility:public"],
)

go_library(
    name = "kvcap",
    srcs = [
        "kv_read_action_generated.go",
        "kv_write_target_generated.go",
        "kvcaptest/read_action_mock_generated.go",  # keep
        "kvcaptest/write_target_mock_generated.go",  # keep
        "read_action_builders_generated.go",
        "write_target_builders_generated.go",
    ],
    importpath = "github.com/smartcontractkit/capabilities/kvstore/kvcap",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_smartcontractkit_chainlink_common//pkg/capabilities",
        "@com_github_smartcontractkit_chainlink_common//pkg/capabilities/consensus/ocr3/ocr3cap",
        "@com_github_smartcontractkit_chainlink_common//pkg/workflows/sdk",
    ],
)
