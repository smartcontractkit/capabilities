{
  "$id": "https://github.com/smartcontractkit/capabilities/kvstore/kvcap/kv-store-target@1.0.0",
  "$defs": {
    "TargetInputs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Input parameters for the Key-Value Store Target. The report must encode the key-value pairs to write. Key must be a string and value must be bytes. Example: { foo: bytes(value1)', bar: bytes(value2) }",
      "properties": {
        "signedReport": {
          "$ref": "https://raw.githubusercontent.com/smartcontractkit/chainlink-common/refs/heads/main/pkg/capabilities/consensus/ocr3/ocr3cap/ocr3cap_common-schema.json#/$defs/SignedReport"
        }
      },
      "required": ["signedReport"]
    }
  },
  "description": "Key-Value Store Target",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "inputs": {
      "$ref": "#/$defs/TargetInputs"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration for the Key-Value Store Target. No configuration options are available at this time.",
      "properties": {},
      "required": []
    }
  },
  "required": ["inputs"]
}
