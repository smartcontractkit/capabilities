{
  "name": "cron",
  "projectType": "capability",
  "projectRoot": "capabilities/cron",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "golangci-lint run ./..."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go mod tidy"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "CGO_ENABLED='0' GOARCH='amd64' go build -o ./../bin/amd64/{projectName} .",
          "CGO_ENABLED='0' GOARCH='arm64' go build -o ./../bin/arm64/{projectName} ."
        ]
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "grep -rl \"^// Code generated by \"| xargs -r rm",
          "go generate -x ./..."
        ],
        "parallel": false
      }
    }
  }
}
