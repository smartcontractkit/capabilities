{
  "name": "aptos",
  "projectType": "capability",
  "implicitDependencies": ["loopserver"],
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "golangci-lint run ./..."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test ./... -coverpkg=./... -coverprofile=coverage.txt"
      }
    },
    "race": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -race ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go mod tidy"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "CGO_ENABLED='0' GOOS='linux' GOARCH='amd64' go build -o ./../bin/amd64/{projectName} .",
          "CGO_ENABLED='0' GOOS='linux' GOARCH='arm64' go build -o ./../bin/arm64/{projectName} ."
        ]
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "grep -rl \"^// Code generated by \"| xargs -r rm",
          "go generate -x ./...",
          "find . -type f -name .mockery.yaml -execdir mockery \\; ## Execute mockery for all .mockery.yaml files"
        ],
        "parallel": false
      }
    }
  }
}
