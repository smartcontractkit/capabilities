{
  "$id": "https://github.com/smartcontractkit/capabilities/workflowevent/workfloweventcap/workflowevent-target@1.0.0",
  "description": "A target that emits events through an OTEL client",
  "$defs": {
    "payload": {
      "type": "object",
      "properties": {
        "payload": {
          "type": "object",
          "additionalProperties": true,
          "examples": [
            {
              "eventName": "Web API target triggered",
              "data": {
                "field": "value"
              }
            },
            {
              "eventName": "Database entry updated",
              "recordID": "abc123",
              "status": "active"
            }
          ]
        }
      },
      "required": ["payload"],
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "otelEndpoint": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "otelEndpoint": "localhost:4317"
        }
      ]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "config": {
      "$ref": "#/$defs/config"
    },
    "inputs": {
      "$ref": "#/$defs/payload"
    }
  },
  "required": ["config","inputs"]
}
