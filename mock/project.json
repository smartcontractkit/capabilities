{
  "name": "mock",
  "projectType": "capability",
  "projectRoot": "capabilities/mock",
  "implicitDependencies": ["loopserver"],
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "env GOWORK=off golangci-lint run ./..."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "GOWORK=off go test ./... -coverpkg=./... -coverprofile=coverage.txt"
      }
    },
    "race": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "GOWORK=off go test -race ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go mod tidy"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "CGO_ENABLED='0' GOOS='linux' GOARCH='amd64' GOWORK=off go build -o ./../bin/amd64/{projectName} .",
          "CGO_ENABLED='0' GOOS='linux' GOARCH='arm64' GOWORK=off go build -o ./../bin/arm64/{projectName} .",
          "CGO_ENABLED='0' GOOS='darwin' GOARCH='arm64' GOWORK=off go build -o ./../bin/arm64-darwin/{projectName} ."
        ]
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "grep -rl \"^// Code generated by \"| xargs -r rm",
          "GOWORK=off go generate -x ./..."
        ],
        "parallel": false
      }
    }
  }
}
