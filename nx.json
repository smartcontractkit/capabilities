{
  "defaultBase": "main",
  "installation": {
    "version": "22.5.1"
  },
  "parallel": 4,
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/.github/**",
      "{workspaceRoot}/.nx/**",
      "{workspaceRoot}/sonar-project.properties"
    ],
    "lint": [
      "{workspaceRoot}/.golangci.yml"
    ]
  },
  "targetDefaults": {
    "build": {
      "inputs": [
        "sharedGlobals"
      ]
    },
    "lint": {
      "inputs": [
        "sharedGlobals",
        "lint"
      ]
    },
    "generate": {
      "inputs": [
        "sharedGlobals"
      ]
    },
    "test": {
      "inputs": [
        "sharedGlobals"
      ]
    },
    "tidy": {
      "inputs": [
        "sharedGlobals"
      ]
    },
    "update-libs": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "go get github.com/smartcontractkit/capabilities/libs@{args.version}",
          "{workspaceRoot}/nx run tidy"
        ],
        "parallel": false
      }
    }
  },
  "$schema": "./node_modules/nx/schemas/nx-schema.json"
}