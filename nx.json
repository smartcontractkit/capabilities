{
  "defaultBase": "main",
  "installation": {
    "version": "19.8.2"
  },
  "parallel": 4,
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/.github/**",
      "{workspaceRoot}/.nx/**",
      "{workspaceRoot}/sonar-project.properties"
    ],
    "lint": [
      "{workspaceRoot}/.golangci.yml"
    ]
  },
  "targetDefaults": {
    "build": {
      "inputs": ["sharedGlobals"]
    },
    "lint": {
      "inputs": ["sharedGlobals", "lint"]
    },
    "generate": {
      "inputs": ["sharedGlobals"]
    },
    "test": {
      "inputs": ["sharedGlobals"]
    },
    "tidy": {
      "inputs": ["sharedGlobals"]
    }
  }
}
