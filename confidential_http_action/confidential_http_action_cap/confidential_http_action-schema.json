{
    "$id": "https://github.com/smartcontractkit/capabilities/confidential_http_action/confidential-http-action@1.0.0",
    "description": "Confidential HTTP action",
    "$defs": {
        "Enclave": {
            "type": "object",
            "properties": {
                "ID": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                },
                "URL": {
                    "type": "string"
                },
                "TrustedValues": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                },
                "EnclaveType": {
                    "type": "string"
                },
                "ExtraData": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                }
            },
            "additionalProperties": false,
            "required": [
                "ID",
                "URL",
                "TrustedValues",
                "Type",
                "ExtraData"
            ]
        },
        "Request": {
            "type": "object",
            "properties": {
                "url": {
                    "type": "string",
                    "description": "The URL to send the request to"
                },
                "method": {
                    "type": "string",
                    "description": "The HTTP method to use for the request"
                },
                "headers": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "The headers to include in the request"
                },
                "body": {
                    "type": "string",
                    "description": "The body of the request"
                },
                "customRootCaCertPEM": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    },
                    "description": "Custom root CA certificate in PEM format"
                },
                "publicTemplateValues": {
                    "type": "object",
                    "additionalProperties": true
                }
            },
            "additionalProperties": false,
            "required": [
                "url",
                "method",
                "headers",
                "body"
            ]
        },
        "Config": {
            "type": "object",
            "properties": {
                "Enclaves": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Enclave"
                    }
                },
                "VaultDONID": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                }
            },
            "required": [
                "Enclaves",
                "VaultDONID"
            ]
        },
        "Input": {
            "type": "object",
            "properties": {
                "requests": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Request"
                    }
                },
                "ciphertextTemplateNames": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Names of ciphertexts to be used in the request"
                }
            },
            "required": [
                "requests",
                "ciphertextTemplateNames"
            ],
            "additionalProperties": false
        },
        "Output": {
            "properties": {
                "responses": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                }
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
                "payload"
            ]
        }
    },
    "type": "object",
    "properties": {
        "config": {
            "$ref": "#/$defs/Config"
        },
        "inputs": {
            "$ref": "#/$defs/Input"
        },
        "outputs": {
            "$ref": "#/$defs/Output"
        }
    },
    "required": [
        "config",
        "inputs",
        "outputs"
    ],
    "additionalProperties": false
}