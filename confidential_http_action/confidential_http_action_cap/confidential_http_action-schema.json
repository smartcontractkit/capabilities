{
    "$id": "https://github.com/smartcontractkit/capabilities/confidential_http_action/confidential_http_action_cap/confidential-http-action@1.0.0",
    "description": "Confidential HTTP action",
    "$defs": {
        "Enclave": {
            "type": "object",
            "properties": {
                "ID": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                },
                "URL": {
                    "type": "string"
                },
                "TrustedValues": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                },
                "EnclaveType": {
                    "type": "string"
                },
                "ExtraData": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                }
            },
            "additionalProperties": false,
            "required": [
                "ID",
                "URL",
                "TrustedValues",
                "Type",
                "ExtraData"
            ]
        },
        "Request": {
            "type": "object",
            "properties": {
                "url": {
                    "type": "string",
                    "description": "The URL to send the request to"
                },
                "method": {
                    "type": "string",
                    "description": "The HTTP method to use for the request"
                },
                "headers": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "The headers to include in the request"
                },
                "body": {
                    "type": "string",
                    "description": "The body of the request"
                },
                "customRootCaCertPEM": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    },
                    "description": "Custom root CA certificate in PEM format"
                },
                "publicTemplateValues": {
                    "type": "object",
                    "additionalProperties": true
                }
            },
            "additionalProperties": false,
            "required": [
                "url",
                "method",
                "headers",
                "body"
            ]
        },
        "SecretIdentifier": {
            "type": "object",
            "properties": {
                "key": {
                    "type": "string",
                    "description": "The key of the secret"
                },
                "namespace": {
                    "type": "string",
                    "description": "The namespace of the secret"
                },
                "owner": {
                    "type": "string",
                    "description": "The owner of the secret"
                }
            },
            "required": [
                "key",
                "namespace"
            ],
            "additionalProperties": false
        },
        "Config": {
            "type": "object",
            "properties": {
                "Enclaves": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Enclave"
                    }
                },
                "VaultDONID": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    }
                }
            },
            "required": [
                "Enclaves",
                "VaultDONID"
            ]
        },
        "Input": {
            "type": "object",
            "properties": {
                "requests": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Request"
                    }
                },
                "vaultDONSecrets": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/SecretIdentifier"
                    },
                    "description": "List of Vault DON secrets to fetch"
                }
            },
            "required": [
                "requests",
                "vaultDONSecrets"
            ],
            "additionalProperties": false
        },
        "Output": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "responses": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "statusCode": {
                                "type": "integer",
                                "description": "The HTTP status code of the response"
                            },
                            "body": {
                                "type": "array",
                                "items": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "maximum": 255
                                },
                                "description": "The body of the response"
                            }
                        },
                        "required": [
                            "statusCode",
                            "body"
                        ]
                    }
                }
            },
            "required": [
                "responses"
            ]
        }
    },
    "type": "object",
    "properties": {
        "config": {
            "$ref": "#/$defs/Config"
        },
        "inputs": {
            "$ref": "#/$defs/Input"
        },
        "outputs": {
            "$ref": "#/$defs/Output"
        }
    },
    "required": [
        "config",
        "inputs",
        "outputs"
    ],
    "additionalProperties": false
}