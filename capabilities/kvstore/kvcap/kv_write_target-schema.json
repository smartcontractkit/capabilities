{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smartcontractkit/capabilities/kvstore/kvcap/kv-store@1.0.0",
  "$defs": {
    "Inputs": {
      "type": "object",
      "additionalProperties": false,
      "description": "Input parameters for the Key-Value Store Target.",
      "properties": {
        "signedReport": {
          "$ref": "https://raw.githubusercontent.com/smartcontractkit/chainlink-common/rtinianov_remoterefs/pkg/capabilities/consensus/ocr3/ocr3cap/ocr3cap_common-schema.json#/$defs/SignedReport"
        }
      },
      "required": ["signedReport"]
    }
  },
  "description": "Key-Value Store Target",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "inputs": {
      "$ref": "#/$defs/Inputs"
