{
  "name": "kvstore",
  "projectType": "capability",
  "projectRoot": "capabilities/kvstore",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx-go/nx-go:build",
      "options": {
        "main": "{projectRoot}/main.go"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run {projectRoot}"
      }
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    }
  }
}
