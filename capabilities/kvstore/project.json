{
  "name": "kvstore",
  "projectType": "capability",
  "projectRoot": "capabilities/kvstore",
  "implicitDependencies": ["types"],
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && golangci-lint run ."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && go test ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && go mod tidy"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && go build -o ./../../bin/{projectName} ."
      }
    }
  }
}
