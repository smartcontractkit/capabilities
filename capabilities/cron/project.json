{
  "name": "cron",
  "projectType": "capability",
  "projectRoot": "capabilities/cron",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && golangci-lint run ."
      }
